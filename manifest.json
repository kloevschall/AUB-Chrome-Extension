{
    "manifest_version": 3,
    "name": "Aalborg University Library Online Access Checker",
    "short_name": "AAU Online",
    "description": "This extension gives easy remote access to publications and databases for students and staff at Aalborg University Library.",
    "version": "2.0",
    "icons": {
        "16": "icon/library16.png",
        "24": "icon/library24.png",
        "32": "icon/library32.png",
        "64": "icon/library64.png",
        "128": "icon/library128.png",
        "256": "icon/library256.png",
        "512": "icon/library512.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Check for online access"
    },
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "https://alma-services-1.aub.aau.dk/UmbracoSupporter/*"
    ]
}
